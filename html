<section id="inicio" class="section inicio">

<div class="texto">
<h1>Estude para o seu futuro</h1>
<p>O WeCan ajuda você a estudar para vestibulares e universidades.</p>

<div class="botoes-estudo">

    <button class="botao-opcao">
    <i class="fa-solid fa-book-open"></i>
    Estudar por matérias
    </button>
    
    <button class="botao-opcao">
    <i class="fa-solid fa-file-pen"></i>
    Simulados
    </button>
    
    <button class="botao-opcao">
